# =============================================================================
# Hotel TimeTrack — Environment Variables
# =============================================================================
# Copy this file to `.env` for local development, or set the same variables
# in your hosting provider's dashboard (Render, Railway, etc.).
#
#   cp .env.example .env
#
# Never commit `.env` to git — it is already listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# `production` enables strict checks (e.g. JWT_SECRET must be set).
# Leave unset locally; set to `production` on Render / Railway.
NODE_ENV=production

# Port the HTTP server listens on. Render and Railway inject this automatically;
# you usually do NOT need to set it manually in production.
PORT=3000

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Secret used to sign JWT auth tokens. REQUIRED in production.
# Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# -----------------------------------------------------------------------------
# Initial admin (only used the very first time the database is empty)
# -----------------------------------------------------------------------------
# If `data/users.json` is empty on first boot, the server creates a single
# admin account using these credentials. After signing in, change the password
# from "My Account" and remove these env vars (or keep them — they are ignored
# once any user exists).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe2026!

# -----------------------------------------------------------------------------
# Persistent data location
# -----------------------------------------------------------------------------
# Path where JSON data files (users, hotels, shifts, corrections) are stored.
# - Local development: leave unset — defaults to `./data` next to server.js.
# - Render: mount a persistent disk and set DATA_DIR to its mount path,
#   e.g. `/var/data`.
# - Railway: attach a volume and set DATA_DIR to its mount path,
#   e.g. `/data`.
# IMPORTANT: without a persistent disk, all users and shifts are lost on every
# deploy because Render/Railway filesystems are ephemeral.
# DATA_DIR=/var/data
